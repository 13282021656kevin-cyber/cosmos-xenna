{
    "python.analysis.autoFormatStrings": true,
    "editor.formatOnSave": true,
    "git.detectSubmodules": false,
    "python.languageServer": "Pylance",
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "[markdown]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.markdownlint": "explicit"
        }
    },
    "markdownlint.config": {
        "default": true,
        "MD013": {
            "code_blocks": false,
            "line_length": 110,
            "tables": false,
        },
        "MD024": false, // This one has a lot of false posititves.
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "cosmos_xenna"
    ],
    "ruff.interpreter": [
        "${workspaceFolder}/.venv/bin/python"
    ],
    // This project standardizes on ruff + pyright/pylance (see pyproject.toml).
    // Disable pylint so the IDE doesn't surface warnings the project doesn't enforce.
    "pylint.enabled": false, // ms-python.pylint extension
    "python.linting.pylintEnabled": false, // legacy built-in linting
    "python.linting.enabled": false
}
